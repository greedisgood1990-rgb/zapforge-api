# Server
NODE_ENV=production
HOST=0.0.0.0
PORT=2785
PUBLIC_URL=http://localhost:2785
CORS_ORIGIN=*

# Security
API_KEY=change-this-super-secret-key
REQUIRE_API_KEY=true
WEBHOOK_TIMEOUT_MS=8000
WEBHOOK_MAX_RETRIES=3
RATE_LIMIT_MAX=240
RATE_LIMIT_WINDOW=1 minute

# Storage
DATA_DIR=./data
SESSION_DIR=./data/sessions
STORE_FILE=./data/store.json
MEDIA_DIR=./data/media

# Engine
DEFAULT_ENGINE=baileys
APP_BROWSER_NAME=ZapForge

# Compliance / safety defaults
RESPONSIBLE_MODE=true
MAX_MESSAGES_PER_MINUTE_PER_SESSION=60
