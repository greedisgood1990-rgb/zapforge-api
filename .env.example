# Server
NODE_ENV=production
HOST=0.0.0.0
PORT=9467
PUBLIC_URL=http://localhost:9467
CORS_ORIGIN=*

# Security
API_KEY=change-this-super-secret-key
REQUIRE_API_KEY=true
WEBHOOK_TIMEOUT_MS=8000
WEBHOOK_MAX_RETRIES=3
RATE_LIMIT_MAX=240
RATE_LIMIT_WINDOW=1 minute

# Storage
DATA_DIR=./data
SESSION_DIR=./data/sessions
STORE_FILE=./data/store.json
MEDIA_DIR=./data/media

# Engine
DEFAULT_ENGINE=baileys
APP_BROWSER_NAME=ZapForge

# Session connection policy
PAIRING_CODE_COOLDOWN_MS=60000
PAIRING_CODE_WINDOW_MS=600000
PAIRING_CODE_MAX_ATTEMPTS=3
PAIRING_CODE_LOCKOUT_MS=600000
PAIRING_CODE_STABILIZATION_MS=3000
PAIRING_CODE_TTL_MS=180000
RECONNECT_BASE_DELAY_MS=5000
RECONNECT_MAX_DELAY_MS=120000
RECONNECT_MAX_ATTEMPTS=6
RECONNECT_JITTER_MS=3000

# Interactive messages
INTERACTIVE_MESSAGE_FALLBACK=true
INTERACTIVE_MAX_BUTTONS=3

# Compliance / safety defaults
RESPONSIBLE_MODE=true
MAX_MESSAGES_PER_MINUTE_PER_SESSION=60

# Groups
GROUP_MENTION_MAX_PARTICIPANTS=1024
GROUP_PARTICIPANT_BATCH_MAX=100
