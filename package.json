{
  "name": "zapforge-api",
  "version": "1.2.0",
  "description": "Self-hosted WhatsApp gateway with controlled session lifecycle, QR and pairing-code authentication, group management, interactive messages and signed webhooks.",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "lint": "eslint . --ext .ts",
    "format": "prettier --write .",
    "test": "npm run build && node --test tests/*.test.mjs"
  },
  "keywords": [
    "whatsapp-api",
    "baileys",
    "self-hosted",
    "webhooks",
    "multi-session",
    "rest-api",
    "open-source",
    "whatsapp-groups",
    "interactive-messages",
    "polls",
    "buttons"
  ],
  "author": "Renato Gomes",
  "license": "MIT",
  "engines": {
    "node": ">=20.10.0"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.1",
    "@fastify/multipart": "^9.0.3",
    "@fastify/rate-limit": "^10.1.1",
    "@fastify/static": "^8.0.2",
    "@fastify/swagger": "^9.4.2",
    "@fastify/swagger-ui": "^5.2.2",
    "@fastify/websocket": "^11.0.1",
    "@whiskeysockets/baileys": "^6.7.23",
    "dotenv": "^16.4.7",
    "fastify": "^5.2.1",
    "nanoid": "^5.0.9",
    "pino-pretty": "^13.0.0",
    "qrcode": "^1.5.4",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@types/qrcode": "^1.5.5",
    "eslint": "^9.17.0",
    "prettier": "^3.4.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
